{
  "_comment": "A100 40GB pretrain — bf16. Trimmed to fit ~10h allowance at measured ~20k tok/s: 6500 steps x 98k tok = ~640M tokens (~8.9h), cosine lands fully on min_lr. 8x24 keeps the 248k-vocab logits within 40GB.",
  "device": "cuda",
  "batch_size": 8,
  "grad_accum": 24,
  "use_gradient_checkpointing": false,
  "train_steps": 6500,
  "warmup_steps": 200,
  "eval_steps": 500,
  "eval_iters": 100,
  "save_every": 500,
  "lr": 3e-4,
  "min_lr": 3e-5,
  "use_amp": true,
  "amp_dtype": "bf16",
  "use_fla": true,
  "compile": false,
  "train_path": "data/corpus_v4/train.jsonl",
  "dev_path": "data/corpus_v4/val.jsonl",
  "out_ckpt": "checkpoints/pretrain_a100_v4.pt",
  "log_dir": "logs/pretrain_a100_v4",
  "hf_repo": "Saurab0/akshara-pretrain"
}
