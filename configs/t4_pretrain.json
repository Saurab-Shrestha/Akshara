{
  "_comment": "T4 pretrain with 308M model, SmolLM-style data (FineWeb-2 + FineWeb-Edu + Wikipedia)",
  "device": "cuda",
  "batch_size": 2,
  "grad_accum": 8,
  "use_gradient_checkpointing": false,
  "train_steps": 50000,
  "warmup_steps": 500,
  "eval_steps": 500,
  "eval_iters": 100,
  "save_every": 1000,
  "lr": 3e-4,
  "min_lr": 3e-5,
  "use_amp": false,
  "use_fla": true,
  "compile": false,
  "train_path": "data/corpus_v4/train.jsonl",
  "dev_path": "data/corpus_v4/val.jsonl",
  "out_ckpt": "checkpoints/pretrain_t4_v4.pt",
  "log_dir": "logs/pretrain_t4_v4"
}
